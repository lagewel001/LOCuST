@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix grddl: <http://www.w3.org/2003/g/data-view#> .
@prefix hg: <http://rdf.histograph.io/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sdmx-code: <http://purl.org/linked-data/sdmx/2009/code#> .
@prefix sdmx-concept: <http://purl.org/linked-data/sdmx/2009/concept#> .
@prefix sdmx-freqno: <https://vocabs.cbs.nl/begrippen//def/sdmx-notation#frequency> .
@prefix sdmx-measure: <http://purl.org/linked-data/sdmx/2009/measure#> .
@prefix sdmx-notation: <https://vocabs.cbs.nl/sdmx-notation_type#> .
@prefix sesame: <http://www.openrdf.org/schema/sesame#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix cbs: <https://vocabs.cbs.nl/def/> .
@prefix freq: <https://vocabs.cbs.nl/def/frequenties/> .

rdfs:subClassOf rdfs:label "Sub class of"@en, "Subklasse van"@nl .


cbs:statline-notation a owl:DatatypeProperty;
  rdfs:isDefinedBy "StatLine database coderingen"@nl;
  rdfs:label "StatLine code"@nl, "StatLine notation"@en;
  rdfs:subPropertyOf skos:notation .

cbs:sdmx-notation a owl:DatatypeProperty;
  rdfs:domain skos:Concept;
  rdfs:isDefinedBy <https://sdmx.org/wp-content/uploads/01_sdmx_cog_annex_1_cdc_2009.pdf>;
  rdfs:label "SDMX code"@nl, "SDMX notation"@en;
  rdfs:range rdf:PlainLiteral;
  rdfs:subPropertyOf skos:notation .


<https://vocabs.cbs.nl/def/frequenties/scheme> a skos:ConceptScheme;
  dct:description "Frequencies of data availability or publication"@en, "Frequenties van data levering of publicatie"@nl;
  dct:issued "2022-01-19";
  dct:source <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/>,
    <https://sdmx.org/wp-content/uploads/CL_FREQ-2.1_February_2021.docx>;
  skos:hasTopConcept cbs:frequenties;
  skos:note "Is largely congruent with sdmx-frequency coding. Also contains a mapping to the ISO 8601 standard where possible. See: https://sdmx.org/wp-content/uploads/CL_FREQ-2.1_February_2021.docx"@en,
    "Komt grotendeels overeen met sdmx frequency. Volgt de SDMX codering. En bevat een mapping naar de ISO 8601 standaard. Zie: https://sdmx.org/wp-content/uploads/CL_FREQ-2.1_February_2021.docx"@nl;
  skos:prefLabel "Frequencies scheme"@en, "Frequenties schema"@nl .

cbs:Frequentie
  a owl:Class ;
  rdfs:subClassOf xsd:duration ;
  skos:prefLabel "Frequency"@en, "Frequentie"@nl .              

cbs:frequenties a skos:Concept;
  skos:inScheme freq:scheme;
  skos:narrower freq:A, freq:A10,
    freq:A2, freq:A3,
    freq:A4, freq:A5,
    freq:A_3, freq:A_4,
    freq:B, freq:D,
    freq:D_2, freq:H,
    freq:H2, freq:H3,
    freq:I, freq:M,
    freq:M12, freq:M2,
    freq:M3, freq:M_2,
    freq:M_3, freq:N,
    freq:OA, freq:OM,
    freq:Q, freq:S,
    freq:VS-M, freq:VS12,
    freq:W, freq:W2,
    freq:W3, freq:W4,
    freq:W_2, freq:W_3,
    freq:_O, freq:_U,
    freq:continue, freq:discontinued,
    freq:once, freq:schoolyear,
    freq:studyear, freq:temp;
  skos:prefLabel "Frequencies"@en, "Frequenties"@nl;
  skos:topConceptOf freq:scheme .

freq:D a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-D, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/D>;
  skos:inScheme freq:scheme;
  skos:notation "D";
  skos:prefLabel "Dagelijks"@nl, "Daily"@en;
  xsd:duration "P1D"^^<xsd:dayTimeDuration>;
  cbs:sdmx-notation "D" .

freq:W_3 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "W_3";
  skos:prefLabel "Drie keer per week"@nl, "Three times a week"@en;
  xsd:duration "P0.33W"^^<xsd:dayTimeDuration> .

freq:A_3 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A_3"^^cbs:sdmx-notation;
  skos:altLabel "Driemaal per jaar"@nl, "Threetimesayear"@en;
  skos:prefLabel "Drie maal per jaar"@nl, "Three times a year"@en;
  xsd:duration "P0.33Y"^^<xsd:yearMonthDuration> .

freq:M_3 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "M_3";
  skos:prefLabel "Drie maal per maand"@nl, "Driemaal per maand"@nl, "Three times a month"@en;
  xsd:duration "P0.33M"^^<xsd:yearMonthDuration> .

freq:H a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.0/H>;
  skos:inScheme freq:scheme;
  skos:notation "H";
  skos:prefLabel "Elk uur"@nl, "Hourly"@en;
  xsd:duration "PT1H"^^<xsd:dayTimeDuration>;
  cbs:sdmx-notation "H" .

freq:N a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-N, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/N>;
  skos:inScheme freq:scheme;
  skos:notation "N";
  skos:prefLabel "Minutely"@en, "Per minuut"@nl;
  xsd:duration "PT1M"^^<xsd:dayTimeDuration>;
  cbs:sdmx-notation "N" .

freq:I a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch <http://purl.org/cld/freq/irregular>, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/I>;
  skos:inScheme freq:scheme;
  skos:notation "I";
  skos:prefLabel "Irregularly"@en, "Onregelmatig"@nl;
  cbs:sdmx-notation "I" .

freq:A3 a skos:Concept, cbs:Frequency;
  skos:altLabel "3-jaarsgemiddelde"@nl, "Triennial"@en, "Threeyearly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A3";
  skos:prefLabel "Per drie jaar"@nl, "Three yearly"@en;
  xsd:duration "P3Y"^^<xsd:yearMonthDuration>;
  cbs:statline-notation "G3" .

freq:M3 a skos:Concept, cbs:Frequency;
  skos:altLabel "3-maandsgemiddelde"@nl, "Driemaandeljks"@nl, "Threemonthly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "M3";
  skos:prefLabel "Per drie maanden"@nl, "Three monthly"@en;
  xsd:duration "P3M"^^<xsd:yearMonthDuration>;
  cbs:statline-notation "M3" .

freq:S a skos:Concept, cbs:Frequency;
  skos:altLabel "Half-yearly"@en, "Halfjaarlijks"@nl, "Semester"@en, "Semester"@nl,
    "Twee maal per jaar"@nl, "Tweemaal per jaar"@nl, "Per halfjaar"@nl, "Twiceyearly"@en, "Sixmonthly"@en;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-S, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/S>;
  skos:inScheme freq:scheme;
  skos:notation "S";
  skos:prefLabel "Per half jaar"@nl, "Twice yearly"@en;
  xsd:duration "P0.5Y"^^<xsd:yearMonthDuration>;
  cbs:sdmx-notation "S" .

freq:M12 a skos:Concept, cbs:Frequency;
  skos:altLabel "Jaarlijks"@nl;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "M12";
  skos:prefLabel "Per jaar"@nl, "Yearly"@en;
  xsd:duration "P12M"^^<xsd:yearMonthDuration> .

freq:A a skos:Concept, cbs:Frequency;
  skos:altLabel "Calender year"@en;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-A, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/A>;
  skos:inScheme freq:scheme;
  skos:notation "A";
  skos:prefLabel "Annual"@en, "Kalenderjaar"@nl;
  xsd:duration "P1Y"^^<xsd:yearMonthDuration>;
  cbs:sdmx-notation "A" .

freq:Q a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-Q, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/Q>;
  skos:inScheme freq:scheme;
  skos:notation "Q";
  skos:prefLabel "Per kwartaal"@nl, "Quarterly"@en;
  xsd:duration "P0.25Y"^^<xsd:yearMonthDuration>;
  cbs:sdmx-notation "Q" .

freq:M a skos:Concept, cbs:Frequency;
  skos:altLabel "Per maand"@nl;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-M, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/M>;
  skos:inScheme freq:scheme;
  skos:notation "M";
  skos:prefLabel "Maandelijks"@nl, "Monthly"@en;
  xsd:duration "P1M"^^<xsd:yearMonthDuration>;
  cbs:sdmx-notation "M" .

freq:A2 a skos:Concept, cbs:Frequency;
  skos:altLabel "2-jaarsgemiddelde"@nl, "Biennial"@en, "Tweejaarlijks"@nl, "Twoyearly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A2";
  skos:prefLabel "Per twee jaar"@nl, "Two yearly"@en;
  xsd:duration "P2Y"^^<xsd:yearMonthDuration>;
  cbs:statline-notation "G2" .

freq:W2 a skos:Concept, cbs:Frequency;
  skos:altLabel "Biweekly"@en, "Per twee weken"@nl;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "W2";
  skos:prefLabel "Tweewekelijks"@nl, "Two-weekly"@en;
  xsd:duration "P2W"^^<xsd:dayTimeDuration> .

freq:A4 a skos:Concept, cbs:Frequency;
  skos:altLabel "4-jaarsgemiddelde"@nl, "Quadrennial"@en, "Fouryearly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A4";
  skos:prefLabel "Four yearly"@en, "Per vier jaar"@nl;
  xsd:duration "P4Y"^^<xsd:yearMonthDuration>;
  cbs:statline-notation "G4" .

freq:A5 a skos:Concept, cbs:Frequency;
  skos:altLabel "5-jaarsgemiddelde"@nl, "Quinquennial"@en, "Vijfjaarlijks"@nl, "Fiveyearly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A5";
  skos:prefLabel "Five yearly"@en, "Per vijf jaar"@nl;
  xsd:duration "P5Y"^^<xsd:yearMonthDuration>;
  cbs:statline-notation "G5" .

freq:W a skos:Concept, cbs:Frequency;
  skos:altLabel "Per week"@nl;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-W, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/W>;
  skos:inScheme freq:scheme;
  skos:notation "W";
  skos:prefLabel "Weekly"@en, "Wekelijks"@nl;
  xsd:duration "P1W"^^<xsd:dayTimeDuration>;
  cbs:sdmx-notation "W" .

freq:_U a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/_U>;
  skos:inScheme freq:scheme;
  skos:notation "_U";
  skos:prefLabel "Niet gespecificeerd"@nl, "Unspecified"@en;
  skos:scopeNote "To be used when a set of values are reported within a time range but not associated to sub ranges. Often this could happen in case of missing or sparse information. (Letâ€™s say we have two observations for 2020 but we do not know if they are part of a monthly reporting or quarterly reporting) (SDMX speficification)"@en;
  cbs:sdmx-notation "_U" .

freq:W_2 a skos:Concept, cbs:Frequency;
  skos:altLabel "Semiweekly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "W_2";
  skos:prefLabel "Twee keer per week"@nl, "Twice-a-week"@en;
  xsd:duration "P0.5W"^^<xsd:dayTimeDuration> .

freq:M_2 a skos:Concept, cbs:Frequency;
  skos:altLabel "Semimonthly"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "M_2";
  skos:prefLabel "Twee maal per maand"@nl, "Twice a month"@en;
  xsd:duration "P0.5M"^^<xsd:yearMonthDuration> .

freq:M2 a skos:Concept, cbs:Frequency;
  skos:altLabel "Bimonthly"@en, "Per twee maanden"@nl;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "M2";
  skos:prefLabel "Tweemaandelijks"@nl, "Twicemonthly"@en;
  xsd:duration "P2M"^^<xsd:yearMonthDuration> .

freq:A_4 a skos:Concept, cbs:Frequency;
  skos:altLabel "Viermaal per jaar"@nl, "Fourtimesayear"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A_4";
  skos:prefLabel "Four times a year"@en, "Vier maal per jaar"@nl;
  xsd:duration "P0.25Y"^^<xsd:yearMonthDuration> .

freq:A10 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "A10";
  skos:prefLabel "Decennial"@en, "Tienjaarlijks"@nl;
  xsd:duration "P10Y"^^<xsd:yearMonthDuration> .

freq:W3 a skos:Concept, cbs:Frequency;
  skos:altLabel "Per drie weken"@nl;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "W3";
  skos:prefLabel "Driewekelijks"@nl, "Triweekly"@en;
  xsd:duration "P3W"^^<xsd:dayTimeDuration> .

freq:W4 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "W4";
  skos:prefLabel "Four-weekly"@en, "Vierwekelijks"@nl;
  xsd:duration "P4W"^^<xsd:dayTimeDuration> .

freq:D_2 a skos:Concept, cbs:Frequency;
  skos:altLabel "Twice a day"@en;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "D_2";
  skos:prefLabel "Twee keer per dag"@nl, "Twice-a-day"@en;
  xsd:duration "P0.5D"^^<xsd:dayTimeDuration> .

freq:H2 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "H2";
  skos:prefLabel "Bihourly"@en, "Per twee uur"@nl;
  xsd:duration "PT2H"^^<xsd:dayTimeDuration> .

freq:H3 a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "H3";
  skos:prefLabel "Per drie uur"@nl, "Trihourly"@en;
  xsd:duration "PT3H"^^<xsd:dayTimeDuration> .

freq:B a skos:Concept, cbs:Frequency;
  skos:altLabel "Week days"@en;
  skos:broader cbs:frequenties;
  skos:exactMatch sdmx-code:freq-B, <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/B>;
  skos:inScheme freq:scheme;
  skos:notation "B";
  skos:prefLabel "Daily business week"@en, "Weekdagen"@nl;
  xsd:duration "PD1/D5"^^<xsd:dayTimeDuration>;
  cbs:sdmx-notation "B" .

freq:OA a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "OA";
  skos:prefLabel "Enige jaren"@nl, "Occasional annual"@en .

freq:OM a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "OM";
  skos:prefLabel "Enige maanden"@nl, "Occasional monthly"@en .

freq:continue a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch <http://purl.org/cld/freq/continuous>;
  skos:inScheme freq:scheme;
  skos:notation "CO";
  skos:prefLabel "Continue"@nl, "Continuous"@en .

freq:schoolyear a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "SA";
  skos:prefLabel "School year"@en, "Schooljaar"@nl;
  skos:scopeNote "Periode van een schooljaar: bijvoorbeeld beginnend in september en eindigend in juli van het volgende jaar"@nl .

freq:studyear a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "SU";
  skos:prefLabel "Studiejaar"@nl, "Study year"@en;
  skos:scopeNote "Periode van een studiejaar: bijvoorbeeld beginnend in september en eindigend in juli van het volgende jaar"@nl .

freq:discontinued a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch <http://purl.org/cld/accpol/closed>;
  skos:inScheme freq:scheme;
  skos:notation "ST";
  skos:prefLabel "Discontinued"@en, "Stopgezet"@nl .

freq:once a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "ON";
  skos:altLabel "Onceonly"@en;
  skos:prefLabel "Eenmalig"@nl, "Once only"@en;
  cbs:sdmx-notation "_Z" .

freq:temp a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:closeMatch <http://purl.org/cld/accpol/passive>;
  skos:inScheme freq:scheme;
  skos:notation "TS";
  skos:prefLabel "Temporarily halted"@en, "Tijdelijk stopgezet"@nl .

freq:_O a skos:Concept, cbs:Frequency;
  skos:broader cbs:frequenties;
  skos:exactMatch <https://registry.sdmx.org/ws/public/sdmxapi/rest/codelist/SDMX/CL_FREQ/2.1/_O>;
  skos:inScheme freq:scheme;
  skos:prefLabel "Other"@en, "Overig"@nl;
  skos:scopeNote "To be used when the qualitative or quantitative values that a variable takes in a data set is associated to multiple occurrences with frequency other than the already defined ones (for example every 5 hours and 32 minutes etc.)"@en;
  cbs:sdmx-notation "_O" .

freq:VS12 a skos:Concept, cbs:Frequency;
  <http://schema.org/duration> "P12M"^^<xsd:yearMonthDuration>;
  rdfs:subClassOf freq:M12;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "VS12";
  skos:prefLabel "Advancing yearly"@en, "Jaarlijks voortschrijdend"@nl;
  skos:scopeNote "Het jaar continueert telkens met een maand: periode februari 1998 t/m januari 1999 en volgend: maart 1998 t/m februari 1999"@nl,
    "The year advances with one month each period: February 1998 / January 1999 and next: March 1998 / February 1999"@en .

freq:VS-M a skos:Concept, cbs:Frequency;
  <http://schema.org/duration> "P1M/P12M"^^<xsd:yearMonthDuration>;
  rdfs:subClassOf freq:M;
  skos:broader cbs:frequenties;
  skos:inScheme freq:scheme;
  skos:notation "VS-M";
  skos:prefLabel "Maandelijks voortschrijdend"@nl, "Monthly advancing"@en;
  skos:scopeNote "In het jaar wordt telkens een maand toegevoegd: periode januari 1998 t/m februari 1998 en volgend: januari 1998 t/m maart 1998"@nl,
    "In the year one month is added for each period: January 1998 / February 1998 and next: January 1998 / March 1998"@en .
